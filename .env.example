# ── 模型設定（issue #27：全系統唯一的模型設定來源，LiteLLM 格式 provider/model）──
# 主模型：AI 助理與分析頁共用。範例：
#   openai/deepseek-v4-flash（OpenCode 等 OpenAI 相容端點，需搭配 OPENAI_API_BASE/KEY）
#   gemini/gemini-2.5-flash（需 GEMINI_API_KEY）
LLM_MODEL=gemini/gemini-2.5-flash

# 備援模型（逗號分隔）：主模型掉線時依序自動切換
LLM_FALLBACK_MODELS=openai/kimi-k2.6,gemini/gemini-2.5-flash

# 分析副任務別名（選填）：新聞歸類/翻譯等量大任務可指到更便宜的模型
# LLM_ANALYSIS_MODEL=gemini/gemini-2.5-flash

# ── 供應商金鑰（依你選的模型填對應的）──
# OPENAI_API_BASE=https://opencode.ai/zen/go/v1
# OPENAI_API_KEY=replace_with_key
GEMINI_API_KEY=replace_with_gemini_api_key

# ── 新聞來源（供應鏈風險頁）──
# GNEWS_API_KEY=replace_with_gnews_api_key

# ── LINE Bot（選用）──
LINE_CHANNEL_ACCESS_TOKEN=replace_with_line_channel_access_token
LINE_CHANNEL_SECRET=replace_with_line_channel_secret

# LINE morning briefing is opt-in and is sent only to this comma-separated allowlist.
LINE_BRIEFING_ENABLED=false
# LINE_BRIEFING_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Optional: override the default SQLite path data/erp.db
# ERP_DB_PATH=C:\ERP專案\data\erp.db

# Optional: seed Agent Dashboard with synthetic demo records. Keep disabled for real data.
# ERP_ENABLE_DEMO_SEED=false
